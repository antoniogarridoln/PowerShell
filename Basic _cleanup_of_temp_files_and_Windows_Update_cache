## Basic cleanup of temp files and Windows Update cache ##

$TempFolders = @("$env:TEMP\*", "$env:SystemRoot\Temp\*", "$env:SystemRoot\SoftwareDistribution\Download\*")
Remove-Item -Path $TempFolders -Recurse -Force -ErrorAction SilentlyContinue

OR

$TempFolders = @("$env:TEMP*", "$env:SystemRoot\Temp*", "$env:SystemRoot\SoftwareDistribution\Download*")
foreach ($path in $TempFolders) {
if (Test-Path -Path $path) {
# Remove-Item -Path $path -Recurse -Force -ErrorAction SilentlyContinue -WhatIf
Remove-Item -Path $path -Recurse -Force -ErrorAction SilentlyContinue
} else {
Write-Verbose "Path not found: $path"
}
}




# Clear temporary files and check disk usage

Write-Host "Cleaning system and user temp folders..."
Remove-Item -Path "$env:TEMP\*" -Recurse -Force -ErrorAction SilentlyContinue
Remove-Item -Path "C:\Windows\Temp\*" -Recurse -Force -ErrorAction SilentlyContinue

Write-Host "Current Disk Usage for C Drive:"
Get-PSDrive C | Select-Object @{N='Used(GB)';E={[math]::round($_.Used/1GB,2)}}, @{N='Free(GB)';E={[math]::round($_.Free/1GB,2)}}
