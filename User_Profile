##Get all profiles in the computer:

Get-CimInstance Win32_UserProfile | Select LocalPath, SID



## Removing profile (agarrido)

Get-CimInstance Win32_UserProfile | Where-Object {
    $_.LocalPath -like "*agarrido*"
} | Remove-CimInstance




## FIND USER PROFILES AND INFORMATION (USERNAME / PATH / SIZE / LAST UPDATE)


Get-CimInstance Win32_UserProfile |
Where-Object { $_.Special -eq $false } |
ForEach-Object {
    $path = $_.LocalPath
    $size = if (Test-Path $path) {
        (Get-ChildItem $path -Recurse -Force -ErrorAction SilentlyContinue |
        Measure-Object Length -Sum).Sum
    } else {
        0
    }

    [PSCustomObject]@{
        UserProfile = Split-Path $path -Leaf
        FullPath    = $path
        SizeGB      = "{0:N2} GB" -f ($size / 1GB)
        LastUsed    = $_.LastUseTime
    }
} |
Sort-Object SizeGB -Descending |
Format-Table -AutoSize



