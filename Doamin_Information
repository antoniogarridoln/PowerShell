## To know full domain name:

(Get-ADDomain).DNSRoot
or
$env:USERDNSDOMAIN



## To know Distinguished Name (DN)

(Get-ADDomain).DistinguishedName

## To know DNS Names on Domain

Resolve-DnsName -Type NS cmack.local



## Toknow HostName from IP

Resolve-DnsName 192.168.68.10
or
nslookup 192.168.68.10
or
ping -a 192.168.68.10
or
Resolve-DnsName 192.168.68.10 -Type PTR



## To know all my DHCP Server

Get-DhcpServerInDC
or 
ipconfig /all
or
([ADSI]"LDAP://CN=DhcpRoot,CN=NetServices,CN=Services,CN=Configuration,DC=cmack,DC=local").Children

If need install Module use:
Import-Module DhcpServer



## To know AD Domain Funcional Leve

Get-ADDomain | Select-Object Name, DomainMode
Get-ADForest | Select-Object ForestMode




## To know wtah is the Primary Domain Controler

(Get-ADDomain).PDCEmulator
or
Get-ADDomain | Select PDCEmulator, RIDMaster, InfrastructureMaster
or
nltest /dsgetdc:cmack.local



# To know All my CGlobal Catalog Servers

Get-ADDomainController -Filter {IsGlobalCatalog -eq $true} |
Select-Object HostName, Site, IPv4Address



## To know all Domain Admins

Get-ADGroupMember "Domain Admins"







