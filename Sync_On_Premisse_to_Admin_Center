## Common reasons to force a sync ##

New user created on-prem and not showing in Microsoft 365.
Password change or account update not appearing in the cloud.
Group membership changes not syncing.
After fixing an Azure AD Connect or connector error.


If you're using Azure AD Connect (most common)

Open PowerShell as Administrator on your Azure AD Connect server and run:

## Delta Sync (CHANGES ONLY – recommended) ##
PowerShellStart-ADSyncSyncCycle -PolicyType Delta

OR

## Simple, reliable “busy/finished” indicator (Get-ADSyncScheduler exposes SyncCycleInProgress for a clean “in progress” signal.) ##
# Run on the Azure AD Connect server (or via Invoke-Command)
Import-Module ADSync -ErrorAction Stop

# Start a Delta sync
Start-ADSyncSyncCycle -PolicyType Delta | Out-Null

# Show a simple spinner until the cycle finishes
$frames = '/ - \ |'.Split(' ')
while ((Get-ADSyncScheduler).SyncCycleInProgress) {
    foreach ($f in $frames) {
        Write-Host -NoNewline "`rSync cycle running... $f"
        Start-Sleep -Milliseconds 150
    }
}
Write-Host "`rSync cycle finished.     "

OR

## Show connector run state (more detail) ( This approach is commonly referenced in operations tips and admin articles to “see if the sync is actually running.”) ##

Import-Module ADSync -ErrorAction Stop

Start-ADSyncSyncCycle -PolicyType Delta | Out-Null

do {
    $status = Get-ADSyncConnectorRunStatus
    if ($status) {
        # Show one line per connector (AD, Entra/Microsoft 365)
        $status | Select-Object ConnectorName, RunState | Format-Table -AutoSize
    } else {
        Write-Host "Waiting for connectors to start..."
    }
    Start-Sleep -Seconds 2
} while ((Get-ADSyncScheduler).SyncCycleInProgress)

Write-Host "Sync cycle finished."



OR


## A “fire‑and‑wait” helper you can reuse (This mirrors community recommendations to check SyncCycleInProgress, gracefully wait, then notify when complete.)##
This function starts a Delta sync, waits safely if one is already running, and prints friendly status as it proceeds.

function Invoke-AADConnectDeltaSync {
    [CmdletBinding()]
    param(
        [int]$PollSeconds = 2
    )

    Import-Module ADSync -ErrorAction Stop

    # If a cycle is already running, wait for it to finish
    while ((Get-ADSyncScheduler).SyncCycleInProgress) {
        Write-Host "Another sync is running... waiting $PollSeconds second(s)..."
        Start-Sleep -Seconds $PollSeconds
    }

    # Start new Delta sync
    Start-ADSyncSyncCycle -PolicyType Delta | Out-Null

    # Live status loop
    $frames = '/ - \ |'.Split(' ')
    do {
        try {
            $run = $null
            if (Get-Command Get-ADSyncConnectorRunStatus -ErrorAction SilentlyContinue) {
                $run = Get-ADSyncConnectorRunStatus
            }
            if ($run) {
                $run | Select-Object ConnectorName, RunState | Format-Table -AutoSize
            } else {
                foreach ($f in $frames) {
                    Write-Host -NoNewline "`rSync cycle running... $f"
                    Start-Sleep -Milliseconds 150
                }
            }
        } catch {
            Write-Host "`rSync cycle running..."
        }
        Start-Sleep -Seconds $PollSeconds
    } while ((Get-ADSyncScheduler).SyncCycleInProgress)

    Write-Host "`rSync cycle finished.     "
}







